    {
      "parameters": {
        "jsCode": "const grouped = {};\n\nfor (const item of $input.all()) {\n  const id = item.json.paper_id;\n  let extractRaw = item.json.extract;\n\n  // 1. Initialisiere das Objekt für die ID, falls noch nicht vorhanden\n  if (!grouped[id]) {\n    grouped[id] = {\n      paper_id: id,\n      paper_infos: {} // Hier fließen alle Extrakte hinein\n    };\n  }\n\n  // 2. Bereinigung der Markdown-Steuerzeichen\n  if (extractRaw && typeof extractRaw === 'string') {\n    try {\n      const cleanJsonString = extractRaw\n        .replace(/```json\\n?|```/g, '')\n        .trim();\n      \n      // 3. String in echtes JSON umwandeln\n      const parsedExtract = JSON.parse(cleanJsonString);\n\n      // 4. Den Inhalt in das paper_infos Objekt mergen\n      // Das führt dazu, dass 'novelties', 'results' etc. alle in paper_infos landen\n      Object.assign(grouped[id].paper_infos, parsedExtract);\n\n    } catch (error) {\n      console.error(`Fehler bei Paper ID ${id}:`, error);\n      grouped[id].paper_infos.error = \"Ungültiges JSON im Extrakt\";\n    }\n  }\n}\n\n// 5. Rückgabe als Liste von Items (ein Item pro Paper)\nreturn Object.values(grouped).map(data => ({ json: data }));\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1840,
        0
      ],
